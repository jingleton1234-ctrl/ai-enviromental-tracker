{
  "manifest_version": 3,
  "name": "AI Resource Tracker",
  "description": "Automatically detects which AI service appears on the current tab and displays it to the user.",
  "version": "1.0.0",
  "icons": {
    "16": "leaf-hand-drawn.png",
    "32": "leaf-hand-drawn.png",
    "48": "leaf-hand-drawn.png",
    "128": "leaf-hand-drawn.png"
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://script.google.com/*",
    "https://script.googleapis.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Resource Tracker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "leaf-hand-drawn.png",
      "32": "leaf-hand-drawn.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
